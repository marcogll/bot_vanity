# --- Servidor Vanessa ---
# Puerto interno donde escucha FastAPI dentro del contenedor.
PORT=8000

# Activa logs/comportamiento de desarrollo si se usa localmente.
DEBUG=False

# Ambiente lógico de ejecución: development, staging o production.
ENV=production

# URL pública de Vanessa. La usa la plataforma/proxy y sirve para configurar webhooks externos.
SERVICE_URL_VANESSA_APP=https://vanessa.example.com

# Host público de Vanessa sin protocolo.
SERVICE_FQDN_VANESSA_APP=vanessa.example.com


# --- Evolution API ---
# URL interna que Vanessa usa para llamar a Evolution dentro de Docker Compose.
EVOLUTION_API_URL=http://evolution-api:8080

# URL pública de Evolution. Debe coincidir con el dominio público de Evolution.
EVOLUTION_SERVER_URL=https://evolution.example.com

# URL pública de Evolution inyectada por la plataforma de deploy.
SERVICE_URL_EVOLUTION_API=https://evolution.example.com

# Host público de Evolution sin protocolo.
SERVICE_FQDN_EVOLUTION_API=evolution.example.com

# API key de Evolution. Se usa para crear/configurar instancia y enviar mensajes.
EVOLUTION_API_KEY=cambia_esta_api_key

# Nombre de la instancia conectada en Evolution.
EVOLUTION_INSTANCE_NAME=sofia

# Número de WhatsApp conectado a Evolution, sin + ni espacios. Evita responderle a la cuenta propia cuando llegan @lid.
EVOLUTION_CONNECTED_NUMBER=5218440000000

# Versión de sesión/cliente WhatsApp que usa Evolution/Baileys.
CONFIG_SESSION_PHONE_VERSION=2.3000.1032691661


# --- OpenAI / LLM ---
# API key de OpenAI usada por Vanessa para generar respuestas.
OPENAI_API_KEY=sk-xxxx

# Modelo de chat usado por Vanessa.
LLM_MODEL=gpt-4o


# --- Seguridad / Memoria ---
# Llave Fernet para cifrar nombres y mensajes guardados. Genera con:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AES_ENCRYPTION_KEY=genera_una_clave_fernet

# Secreto que Evolution debe mandar en el webhook: /webhook?apiKey=...
WEBHOOK_SECRET=cambia_este_webhook_secret

# Días que Vanessa conserva memoria e historial antes de purgar.
MEMORY_RETENTION_DAYS=30


# --- Negocio ---
# Liga oficial de agendamiento que Vanessa compartirá cuando el flujo esté listo.
BOOKING_URL=https://vanityexperience.mx/booking


# --- Base de Datos de Vanessa ---
# Usuario PostgreSQL para la base de Vanessa.
VANITY_DB_USER=vanity_user

# Password PostgreSQL para la base de Vanessa.
VANITY_DB_PASSWORD=cambia_este_password

# Nombre de la base PostgreSQL de Vanessa.
VANITY_DB_NAME=vanity_db

# URL de conexión de Vanessa. En Docker debe apuntar a vanessa-db.
DATABASE_URL=postgresql://vanity_user:cambia_este_password@vanessa-db:5432/vanity_db


# --- Base de Datos de Evolution ---
# Usuario PostgreSQL para Evolution.
EVOLUTION_DB_USER=evolution_user

# Password PostgreSQL para Evolution.
EVOLUTION_DB_PASSWORD=cambia_este_password

# Nombre de la base PostgreSQL de Evolution.
EVOLUTION_DB_NAME=evolution_db
