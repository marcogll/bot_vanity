# --- CONFIGURACIÓN DEL SERVIDOR ---
PORT=8000
DEBUG=False
ENV=production # development / production

# --- EVOLUTION API ---
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_SERVER_URL=https://tu-dominio-evolution.com
EVOLUTION_API_KEY=tu_api_key_segura
EVOLUTION_INSTANCE_NAME=vanity-instance

# --- OPENAI / LLM ---
OPENAI_API_KEY=sk-xxxx...
LLM_MODEL=gpt-4o # o gpt-4o-mini para ahorro de costos

# --- BASE DE DATOS DE VANESSA (DOCKER) ---
VANITY_DB_USER=vanity_user
VANITY_DB_PASSWORD=cambia_este_password
VANITY_DB_NAME=vanity_db
DATABASE_URL=postgresql://vanity_user:cambia_este_password@vanessa-db:5432/vanity_db

# --- BASE DE DATOS DE EVOLUTION (DOCKER) ---
EVOLUTION_DB_USER=evolution_user
EVOLUTION_DB_PASSWORD=cambia_este_password
EVOLUTION_DB_NAME=evolution_db

# --- SEGURIDAD Y MEMORIA ---
AES_ENCRYPTION_KEY=genera_una_clave_32_bytes_base64 # Para cifrar datos sensibles
MEMORY_RETENTION_DAYS=30
WEBHOOK_SECRET=token_para_validar_que_los_mensajes_vienen_de_evolution

# --- NEGOCIO ---
BOOKING_URL=https://vanitynails.fresh.com
